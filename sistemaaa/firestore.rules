rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'nelsonrmachicado@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidEvent(data) {
      return data.keys().hasAll(['clientName', 'clientId', 'eventType', 'date', 'guests', 'status', 'totalAmount', 'advancePayment', 'balancePending', 'paymentDueDate']) &&
             data.clientName is string && data.clientName.size() <= 200 &&
             data.clientId is string && data.clientId.size() <= 100 &&
             data.eventType is string && data.eventType.size() <= 100 &&
             data.date is string && data.date.size() <= 50 &&
             data.guests is number && data.guests >= 0 &&
             data.status in ['Confirmado', 'Pendiente', 'Cancelado', 'Cerrado'] &&
             data.totalAmount is number &&
             data.advancePayment is number &&
             data.balancePending is number &&
             (!('signedContractUrl' in data) || (data.signedContractUrl is string && data.signedContractUrl.size() <= 1000)) &&
             (!('sellerName' in data) || (data.sellerName is string && data.sellerName.size() <= 200));
    }

    function isValidInventoryItem(data) {
      return data.keys().hasAll(['name', 'category', 'boxes', 'unitsPerBox', 'looseUnits', 'pricePerBox', 'pricePerUnit', 'status']) &&
             data.name is string && data.name.size() <= 200 &&
             data.category in ['Mobiliario', 'Catering', 'Tecnología', 'Decoración', 'Bebidas', 'Consumibles'] &&
             data.boxes is number && data.boxes >= 0 &&
             data.unitsPerBox is number && data.unitsPerBox >= 0 &&
             data.looseUnits is number && data.looseUnits >= 0 &&
             data.pricePerBox is number && data.pricePerBox >= 0 &&
             data.pricePerUnit is number && data.pricePerUnit >= 0 &&
             data.status in ['In Stock', 'Low Stock', 'Maintenance'];
    }

    function isValidSale(data) {
      return data.keys().hasAll(['eventId', 'clientName', 'items', 'amount', 'date', 'paymentMethod', 'status']) &&
             data.eventId is string && data.eventId.size() <= 128 &&
             data.clientName is string && data.clientName.size() <= 200 &&
             data.items is list && data.items.size() <= 100 &&
             data.amount is number && data.amount >= 0 &&
             data.date is string && data.date.size() <= 50 &&
             data.paymentMethod in ['Efectivo', 'QR', 'Tarjeta', 'Transferencia'] &&
             data.status in ['Paid', 'Partial', 'Refunded'] &&
             (!('sellerName' in data) || (data.sellerName is string && data.sellerName.size() <= 200)) &&
             (!('isPrinted' in data) || (data.isPrinted is bool));
    }

    function isValidAsset(data) {
      return data.keys().hasAll(['name', 'category', 'quantity', 'condition']) &&
             data.name is string && data.name.size() <= 200 &&
             data.category in ['Cocina', 'Cantina'] &&
             data.quantity is number && data.quantity >= 0 &&
             data.condition in ['Bueno', 'Regular', 'Malo'] &&
             (!('lastMaintenance' in data) || (data.lastMaintenance is string && data.lastMaintenance.size() <= 50));
    }

    // --- Collection Rules ---

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidEvent(incoming());
      allow update: if isSignedIn() && isValidEvent(incoming());
      allow delete: if isAdmin();
    }

    match /inventory/{itemId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidInventoryItem(incoming());
      allow update: if isSignedIn() && isValidInventoryItem(incoming());
      allow delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidSale(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /staff/{staffId} {
      allow read: if isOwner(staffId) || isAdmin();
      allow write: if isAdmin();
    }

    match /assets/{assetId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidAsset(incoming());
      allow update: if isAdmin() && isValidAsset(incoming());
      allow delete: if isAdmin();
    }

    match /config/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable through firebase console or functions
    }
  }
}
